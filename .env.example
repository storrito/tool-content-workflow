# Copy to .env and adjust. .env is git-ignored.

# Web UI basic auth
CONTENT_WORKFLOW_USER=marketing
CONTENT_WORKFLOW_PASSWORD=change-me

# Optional server port
PORT=8080

# bundle.social publishing
BUNDLE_SOCIAL_API_KEY=pk_live_...
BUNDLE_SOCIAL_TEAM_ID=team_...

# Optional: required when publishing to Pinterest unless passed in the UI/CLI
BUNDLE_SOCIAL_PINTEREST_BOARD=
