# Copy to .env and adjust. .env is git-ignored.

# Web UI basic auth
CONTENT_WORKFLOW_USER=marketing
CONTENT_WORKFLOW_PASSWORD=change-me

# Optional server port
PORT=8080

# Optional: public/reachable base URL for this UI when another local service
# runs in a different network namespace/container and cannot reach localhost.
CONTENT_WORKFLOW_PUBLIC_BASE_URL=

# bundle.social publishing
BUNDLE_SOCIAL_API_KEY=pk_live_...
BUNDLE_SOCIAL_TEAM_ID=team_...

# Optional: required when publishing to Pinterest unless passed in the UI/CLI
BUNDLE_SOCIAL_PINTEREST_BOARD=

# Storrito API publishing (recommended for local Instagram Story publishing)
STORRITO_API_BASE=http://7414818a-0c58-4865-aa8b-3b43cc96aa93.localhost:8080/api/v1
STORRITO_API_TOKEN=
STORRITO_INSTAGRAM_USERNAME=
STORRITO_INSTAGRAM_STORY_LINK=
